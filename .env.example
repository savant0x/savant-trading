# Savant Trading Engine — Environment Configuration (TEMPLATE)
# SECRETS ONLY. All non-secret settings go in config/default.toml.
# Copy this file to .env and fill in real values.
#
# IMPORTANT RULES (FID-176):
# - Variable names MUST start with a letter or underscore (e.g., ZEROEX_API_KEY, not 0X_API_KEY).
#   The dotenvy parser aborts the entire .env file on a malformed name. Symptom: 401 errors
#   from tokenrouter, empty Authorization headers, "no API keys" behavior.
# - Don't use leading digits, hyphens, or special chars in var names.
# - Use uppercase + underscores for var names (POSIX convention).
# - Wrap values in double quotes only if they contain spaces. Don't quote the whole value.

# OpenGateway API key (optional — has built-in defaults)
OPENGATEWAY_API_KEY=

# Kraken API keys (required for live trading only)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# CoinMarketCap API key (free tier: 10K calls/month)
COINMARKETCAP_API_KEY=

# NVIDIA NIM API key (free tier: DeepSeek-V4-Flash)
NVIDIA_API_KEY=

# DEX wallet (for real trading)
WALLET_PRIVATE_KEY=

# 0x DEX API key (correct name starts with letter: ZEROEX)
ZEROEX_API_KEY=

# OpenRouter API key
OPENROUTER_API_KEY=
OPENROUTER_MANAGEMENT_KEY=

# CoinGecko API key (Demo tier: 10K calls/month)
COINGECKO_API_KEY=
GOOGLE_API_KEY=

# GitHub Personal Access Token (for releases)
GITHUB_TOKEN=

# TokenRouter API key (M3, the primary LLM)
TOKEN_ROUTER_MANAGEMENT_API_KEY=
TOKEN_ROUTER_API_KEY=
